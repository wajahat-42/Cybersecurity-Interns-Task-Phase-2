{
  "name": "secure-notes-api",
  "version": "1.0.0",
  "description": "A REST API demonstrating cybersecurity best practices: rate limiting, CSRF protection, SQL injection prevention, security headers, and API authentication.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "start:vulnerable": "node app-vulnerable.js",
    "dev": "nodemon app.js"
  },
  "keywords": ["security", "express", "api", "csrf", "sql-injection"],
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "sql.js": "^1.10.3",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
